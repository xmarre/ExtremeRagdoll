+            _proximityTargetSpeed = 1f;
+            _proximityCurrentSpeed = 1f;
+            _closestProximityDistance = float.PositiveInfinity;
+            _closestProximityEnemy = null;
+            _manualTimeOverride = false;
+            _guidanceLastTimestamp = 0;
+        }
