+        private void InitializeGuidanceTimeControl()
+        {
+            ResetGuidanceTimeControl();
+            _guidanceLastTimestamp = Stopwatch.GetTimestamp();
+
+            Settings settings = Settings.Instance;
+            if (settings?.EnableProximityTimeDilation ?? true)
+            {
+                float farSpeed = Clamp(settings?.ProximityFarTimeSpeed ?? 1f, SpeedSteps[0], 1f);
+                _proximityCurrentSpeed = farSpeed;
+                _proximityTargetSpeed = farSpeed;
+                _proximityScanCountdown = 0f;
+                ApplyAutomaticTimeSpeed(farSpeed);
+                Log("Proximity Time Dilation started at " + farSpeed.ToString("0.00") + "x.");
+                return;
+            }
+
+            float fixedSpeed = Clamp(settings?.InitialGuidanceTimeSpeed ?? 0.15f, SpeedSteps[0], 1f);
+            _proximityCurrentSpeed = fixedSpeed;
+            _proximityTargetSpeed = fixedSpeed;
+            SetOwnTimeSpeed(fixedSpeed);
+            Log("Legacy fixed guidance time speed started at " + fixedSpeed.ToString("0.00") + "x.");
+        }
+
+        private void ResetGuidanceTimeControl()
+        {
